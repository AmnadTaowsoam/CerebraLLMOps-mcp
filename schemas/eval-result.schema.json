{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cerebra-mcp/schemas/llmops/eval-result",
  "title": "EvalResult",
  "description": "Schema for an evaluation run result record",
  "type": "object",
  "required": [
    "run_id",
    "suite_id",
    "triggered_by",
    "model_id",
    "agent_id",
    "tenant_id",
    "run_at",
    "total_cases",
    "passed_cases",
    "failed_cases",
    "weighted_pass_rate",
    "pass_threshold",
    "status",
    "recommended_decision",
    "human_review_required",
    "feedback_submitted"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Unique ID for this eval run",
      "pattern": "^eval-run-[a-f0-9-]+$"
    },
    "suite_id": {
      "type": "string",
      "description": "Which eval suite was run"
    },
    "triggered_by": {
      "type": "string",
      "enum": ["version_promotion", "per_run_automated", "periodic_baseline", "on_demand"],
      "description": "What caused this eval run"
    },
    "trigger_details": {
      "type": "object",
      "description": "Additional details about what triggered this run",
      "properties": {
        "prompt_id": { "type": ["string", "null"] },
        "prompt_version": { "type": ["string", "null"] },
        "agent_id": { "type": ["string", "null"] },
        "instruction_version": { "type": ["string", "null"] },
        "run_id_ref": { "type": ["string", "null"] }
      }
    },
    "model_id": {
      "type": "string",
      "description": "Model used for the runs being evaluated"
    },
    "agent_id": {
      "type": "string",
      "description": "Agent whose output was evaluated"
    },
    "tenant_id": { "type": "string" },
    "run_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "total_cases": {
      "type": "integer",
      "minimum": 1
    },
    "passed_cases": {
      "type": "integer",
      "minimum": 0
    },
    "failed_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "failure_reason", "weight"],
        "properties": {
          "case_id": { "type": "string" },
          "case_name": { "type": "string" },
          "failure_reason": { "type": "string" },
          "actual_output_excerpt": { "type": ["string", "null"] },
          "expected": { "type": "string" },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "weighted_pass_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Weighted pass rate (0-100)"
    },
    "pass_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Minimum required pass rate for this suite + agent combination"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "pending", "error"]
    },
    "recommended_decision": {
      "type": "string",
      "enum": ["promote", "reject", "review"]
    },
    "human_review_required": { "type": "boolean" },
    "human_review_completed": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "human_reviewer_id": { "type": ["string", "null"] },
    "human_review_result": {
      "type": ["string", "null"],
      "enum": ["approved", "rejected", "conditional", null]
    },
    "human_review_notes": { "type": ["string", "null"] },
    "feedback_submitted": { "type": "boolean" },
    "feedback_id": { "type": ["string", "null"] },
    "metadata": {
      "type": "object",
      "properties": {
        "context_tokens_used": { "type": ["integer", "null"] },
        "eval_model_id": { "type": ["string", "null"] },
        "eval_cost_usd": { "type": ["number", "null"] }
      }
    }
  },
  "additionalProperties": false
}
